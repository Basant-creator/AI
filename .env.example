# Core AI generation
GEMINI_API_KEY=

# Optional fallback token (used when request/user token is not provided)
GITHUB_TOKEN=

# Optional image provider
PEXELS_API_KEY=

# MongoDB auth storage
# For Atlas, prefer host/query URI without inline credentials if your password
# contains special characters like @. Provide user/password below.
MONGODB_URI=mongodb+srv://cluster-url.mongodb.net/?retryWrites=true&w=majority&appName=YourApp
MONGODB_DB_NAME=ai_website_generator
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_AUTH_DB=admin

# Session auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXP_DAYS=7

# Encryption key for GitHub token-at-rest
# Recommended: generate with
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
