# Express API Gateway — environment variables
# Copy this file to .env and fill in values

# Port the Express gateway listens on (default: 3000)
PORT=3000

# Base URL of the Flask AI engine (default: http://localhost:5000)
# Change this if Flask runs on a different host/port (e.g. in Docker or on a remote server)
FLASK_BASE_URL=http://localhost:5000
